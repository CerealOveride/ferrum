#!/bin/sh
set -e

WHEELS_DIR="/usr/share/ferrum/wheels"

if [ -d "$WHEELS_DIR" ]; then
    pip3 install \
        --no-index \
        --find-links="$WHEELS_DIR" \
        --quiet \
        --break-system-packages \
        smbprotocol pyspnego textual aiofiles send2trash \
        keyring keyrings.alt rich cryptography \
        2>/dev/null || true
fi

exit 0
